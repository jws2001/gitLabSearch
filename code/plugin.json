{
  "main": "index.html",
  "logo": "logo.png",
  "preload": "preload.js",
  "pluginName": "GitLab 项目搜索",
  "description": "快速搜索和打开你的 GitLab 项目",
  "author": "songsong",
  "version": "0.1.0",
  "features": [
    {
      "code": "over",
      "cmds": [
        {
          "type": "over",
          "label": "搜索 GitLab 项目",
          "exclude": "/\\n/",
          "minLength": 1,
          "maxLength": 500
        }
      ]
    },
    {
      "code": "gitlab-search",
      "explain": "搜索 GitLab 项目",
      "cmds": ["gl", "gitlab", "gitlab搜索"]
    },
    {
      "code": "gitlab-settings",
      "explain": "GitLab 插件设置",
      "cmds": ["gl-setup", "gitlab设置"]
    }
  ]
}
